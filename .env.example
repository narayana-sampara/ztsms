COMPOSE_PROJECT_NAME=ztsms

# Public HTTP port on the EC2 instance.
HTTP_PORT=80

# PostgreSQL container settings.
POSTGRES_DB=student_lms
POSTGRES_USER=ztsms
POSTGRES_PASSWORD=change-this-postgres-password

# Backend application settings.
APP_NAME=Zefinity Student LMS API
ENVIRONMENT=production
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ISSUER=ZefinityLms
JWT_AUDIENCE=ZefinityLms.Web
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Replace with your EC2 public URL and/or domain.
BACKEND_CORS_ORIGINS=http://localhost,http://127.0.0.1

# Set to false only when you want to run Alembic manually.
RUN_MIGRATIONS=true
WAIT_FOR_DATABASE=true
